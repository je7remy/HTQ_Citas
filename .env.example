# --- App ---
APP_NAME=SGCM
ENVIRONMENT=production
API_V1_PREFIX=/api/v1

# --- JWT ---
JWT_SECRET_KEY=cambia-esta-clave-en-produccion-min-32-chars-aleatoria
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- DB ---
POSTGRES_USER=sgcm
POSTGRES_PASSWORD=sgcm_secure_password
POSTGRES_DB=sgcm_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- CORS ---
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:80"]

# --- Seed (datos demo del HTQPJB) ---
# true  → en cada arranque el contenedor api ejecuta app.scripts.seed_db
#         (10+ usuarios, 9 médicos, horarios, 40 pacientes, 50 citas, consultas).
#         Las operaciones son idempotentes: no duplica datos existentes.
# false → comportamiento de producción; no toca los datos.
SGCM_SEED=false
