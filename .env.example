# =========================================================
#  SGCM — Plantilla de variables de entorno
#  Copie este archivo como `.env` y ajuste los valores.
# =========================================================

# --- App ---
APP_NAME=SGCM
ENVIRONMENT=production
API_V1_PREFIX=/api/v1

# --- JWT ---
JWT_SECRET_KEY=cambie-esta-clave-en-produccion-min-32-caracteres
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- DB ---
POSTGRES_USER=sgcm
POSTGRES_PASSWORD=sgcm_secure_password
POSTGRES_DB=sgcm_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- CORS ---
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:80"]

# --- Seed (datos demo del HTQPJB) ---
# true  → en cada arranque el contenedor api ejecuta app.scripts.seed_db.
# false → comportamiento de producción; no toca los datos.
SGCM_SEED=false

# =========================================================
#  Respaldos (CU-16)
#  --------------------------------------------------------
#  Modalidad LOCAL:    el .sql se guarda dentro del servidor.
#  Modalidad EXTERNO:  el .sql se copia a un disco USB o ruta
#                      UNC montada en el sistema operativo.
#  Modalidad NUBE:     andamiaje listo; activar instalando
#                      el SDK del proveedor y configurando las
#                      credenciales de acceso.
# =========================================================
SGCM_BACKUP_LOCAL_DIR=/var/backups/sgcm
SGCM_BACKUP_EXTERNAL_DIR=/mnt/backup_externo

# Amazon S3 (boto3)
SGCM_BACKUP_S3_BUCKET=
SGCM_BACKUP_S3_REGION=

# Google Cloud Storage (google-cloud-storage)
SGCM_BACKUP_GCS_BUCKET=

# Azure Blob Storage (azure-storage-blob)
SGCM_BACKUP_AZURE_CONTAINER=
